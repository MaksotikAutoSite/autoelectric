---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="SITRUK — техническая документация">
  
  <div style="background:#11141c;border:1px solid #1a1e2b;border-radius:16px;padding:32px;margin-bottom:24px">
    <a href="/wiki" style="color:#3b82f6;text-decoration:none;font-size:13px">← Назад к базе знаний</a>
    <h1 style="margin-top:16px">SHACMAN — Техническая документация</h1>
    <p style="color:#6b7280">Обновлено: май 2026</p>
  </div>

  <!-- Электрика -->
  <div style="background:#11141c;border:1px solid #1a1e2b;border-radius:16px;padding:32px;margin-bottom:24px">
    <h2 style="margin-bottom:16px">⚡ Электрика</h2>
    <div style="display:flex;flex-direction:column;gap:2px">
      
      <a href="/shacman/SHACMAN_X3000_Евро_4_Евро_5_Электрическая_схема_v2.pdf" target="_blank" 
         style="display:flex;justify-content:space-between;align-items:center;padding:14px 0;border-bottom:1px solid #1a1e2b;text-decoration:none;color:#b0b8c4;font-size:14px">
        <span>📄 SHACMAN_X3000_Евро_4_Евро_5_Электрическая_схема_v2</span>
        <span style="color:#3b82f6;font-size:13px">PDF ↓</span>
      </a>

      <a href="/wiki/shacman/SHACMAN_X3000_Евро_4_Евро_5_Электрическая_схема_v2.pdf" target="_blank" 
         style="display:flex;justify-content:space-between;align-items:center;padding:14px 0;border-bottom:1px solid #1a1e2b;text-decoration:none;color:#b0b8c4;font-size:14px">
        <span>📄 Схема предохранителей — X3000</span>
        <span style="color:#3b82f6;font-size:13px">PDF ↓</span>
      </a>

    </div>
  </div>

  <!-- Двигатель -->
  <div style="background:#11141c;border:1px solid #1a1e2b;border-radius:16px;padding:32px;margin-bottom:24px">
    <h2 style="margin-bottom:16px">🔧 Двигатель</h2>
    <div style="display:flex;flex-direction:column;gap:2px">
      
      <a href="/wiki/shacman/engine-manual.pdf" target="_blank" 
         style="display:flex;justify-content:space-between;align-items:center;padding:14px 0;border-bottom:1px solid #1a1e2b;text-decoration:none;color:#b0b8c4;font-size:14px">
        <span>📄 Руководство по ремонту двигателя WP10</span>
        <span style="color:#3b82f6;font-size:13px">PDF ↓</span>
      </a>

      <a href="/wiki/shacman/engine-diagnostics.pdf" target="_blank" 
         style="display:flex;justify-content:space-between;align-items:center;padding:14px 0;text-decoration:none;color:#b0b8c4;font-size:14px">
        <span>📄 Диагностика двигателя — коды ошибок</span>
        <span style="color:#3b82f6;font-size:13px">PDF ↓</span>
      </a>

    </div>
  </div>

  <!-- Трансмиссия -->
  <div style="background:#11141c;border:1px solid #1a1e2b;border-radius:16px;padding:32px;margin-bottom:24px">
    <h2 style="margin-bottom:16px">🛞 Трансмиссия</h2>
    <div style="display:flex;flex-direction:column;gap:2px">
      
      <a href="/wiki/shacman/gearbox-manual.pdf" target="_blank" 
         style="display:flex;justify-content:space-between;align-items:center;padding:14px 0;text-decoration:none;color:#b0b8c4;font-size:14px">
        <span>📄 КПП Fast Gear — руководство</span>
        <span style="color:#3b82f6;font-size:13px">PDF ↓</span>
      </a>

    </div>
  </div>

  <!-- Тормозная система -->
  <div style="background:#11141c;border:1px solid #1a1e2b;border-radius:16px;padding:32px;margin-bottom:24px">
    <h2 style="margin-bottom:16px">🛑 Тормозная система</h2>
    <div style="display:flex;flex-direction:column;gap:2px">
      
      <a href="/wiki/shacman/abs-manual.pdf" target="_blank" 
         style="display:flex;justify-content:space-between;align-items:center;padding:14px 0;text-decoration:none;color:#b0b8c4;font-size:14px">
